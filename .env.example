# Copier vers .env et adapter au VPS.
# Le site est servi sur DROIDEX_DOMAIN et l'API de synchronisation sur api.DROIDEX_DOMAIN
# (créer les deux entrées DNS).
DROIDEX_DOMAIN=droidex.mondomaine.fr

# Conventions Traefik de votre VPS (docker network ls / config du résolveur ACME)
TRAEFIK_NETWORK=proxy
TRAEFIK_CERTRESOLVER=letsencrypt

# IPs autorisées à atteindre la console d'admin PocketBase (/_/) depuis Internet,
# séparées par des virgules. Par défaut personne : accès via tunnel SSH uniquement.
# Exemple : DROIDEX_ADMIN_IPS=127.0.0.1/32,203.0.113.42/32
DROIDEX_ADMIN_IPS=127.0.0.1/32
